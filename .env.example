# Note:
# Replace localhost with db if you are using Docker Compose and have defined a service named db for your PostgreSQL database.
# Replace localhost with redis if you are using Docker Compose and have defined a service named redis for your Redis instance.

# DB Credentials
DATABASE_URL=postgresql+asyncpg://devsphere_user:devsphere1234@db:5432/devsphere_db 
POSTGRES_USER=devsphere_user
POSTGRES_PASSWORD=devsphere1234
POSTGRES_DB=devsphere_db

# Redis Settings
REDIS_URL=redis://redis:6379/0 
REDIS_HOST=redis 
REDIS_PORT=6379
REDIS_DB=0

# SECURITY Settings
SECRET_KEY=your_secret_key_here
REFRESH_SECRET_KEY=your_refresh_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
